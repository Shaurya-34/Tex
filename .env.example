# Ollama model to use
TEX_MODEL=llama3.2

# Temperature (0.0 = deterministic, 1.0 = creative). Keep low for tool calls.
TEX_TEMPERATURE=0.1

# Max tokens to generate per response.
# JSON tool calls are ~80 tokens. 256 is safe; lower = faster responses.
# Raise to 512+ if the model ever truncates its JSON output.
TEX_MAX_TOKENS=256

# Context window size. Smaller = faster prefill = shorter 'Thinking...' wait.
# 2048 fits the system prompt + conversation history comfortably.
# Raise to 4096+ for very long multi-turn chat sessions.
TEX_NUM_CTX=2048

# Log file path (relative to project root)
TEX_LOG_FILE=logs/tex.log

# Require confirmation before any execution (true/false)
TEX_CONFIRM=true

# Maximum character length for a single LLM argument value (structural args
# like paths and package names). Free-text content (chat messages,
# explanations) automatically get 16x this limit.
# Raise this if your model produces longer structured outputs.
TEX_MAX_ARG_LEN=1024
